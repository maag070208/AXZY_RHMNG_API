generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////////////////////
// ENUMS
////////////////////////////////////////////////////

enum Role {
  ADMIN
  RECURSOS_HUMANOS
  RECLUTADOR
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum VacancyStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  CANCELLED
}

enum ApplicantStatus {
  REGISTERED
  FORM_COMPLETED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  HIRED
  REJECTED
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

////////////////////////////////////////////////////
// USERS
////////////////////////////////////////////////////

model User {
  id       Int        @id @default(autoincrement())
  name     String
  lastName String?
  username String     @unique
  password String
  role     Role
  status   UserStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdVacancies Vacancy[]   @relation("VacancyCreator")
  interviews       Interview[] @relation("InterviewUser")
}

////////////////////////////////////////////////////
// VACANTES
////////////////////////////////////////////////////

model Vacancy {
  id          Int     @id @default(autoincrement())
  title       String?
  description String? @db.Text
  department  String?
  salary      Float?
  positions   Int     @default(1)

  status VacancyStatus @default(DRAFT)

  // token para generar QR
  qrToken String @unique @default(uuid())

  startDate DateTime?
  endDate   DateTime?
  workSchedule String? @db.Text

  slots     VacancySlot[]

  createdById Int?
  createdBy   User? @relation("VacancyCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicants Applicant[]
  interviews Interview[]

  @@index([status])
}

model VacancySlot {
  id        Int      @id @default(autoincrement())
  startTime DateTime
  endTime   DateTime
  positions Int      @default(1)
  
  vacancyId Int
  vacancy   Vacancy  @relation(fields: [vacancyId], references: [id])
  
  applicants Applicant[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([vacancyId])
}

////////////////////////////////////////////////////
// SOLICITANTES
////////////////////////////////////////////////////

model Applicant {
  id Int @id @default(autoincrement())

  firstName String
  lastName  String

  email String?
  phone String?

  birthDate DateTime?

  address String?
  city    String?

  education  String?
  experience String? @db.Text

  resumeUrl String?

  status ApplicantStatus @default(REGISTERED)

  formCompleted Boolean @default(false)

  // informacion adicional del formulario
  formData Json?

  notes String? @db.Text

  vacancyId Int?
  vacancy   Vacancy? @relation(fields: [vacancyId], references: [id])

  slotId    Int?
  slot      VacancySlot? @relation(fields: [slotId], references: [id])

  interviews Interview[]

  documents ApplicantDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vacancyId])
}

////////////////////////////////////////////////////
// ENTREVISTAS / CITAS
////////////////////////////////////////////////////

model Interview {
  id Int @id @default(autoincrement())

  scheduledAt DateTime

  notes String? @db.Text

  status InterviewStatus @default(SCHEDULED)

  vacancyId Int
  vacancy   Vacancy @relation(fields: [vacancyId], references: [id])

  applicantId Int
  applicant   Applicant @relation(fields: [applicantId], references: [id])

  interviewerId Int?
  interviewer   User? @relation("InterviewUser", fields: [interviewerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduledAt])
  @@index([vacancyId])
  @@index([applicantId])
}

////////////////////////////////////////////////////
// DOCUMENTOS DEL CANDIDATO
////////////////////////////////////////////////////

model ApplicantDocument {
  id Int @id @default(autoincrement())

  applicantId Int
  applicant   Applicant @relation(fields: [applicantId], references: [id])

  type String // INE, CURP, CV, COMPROBANTE_DOMICILIO

  fileUrl String

  uploadedAt DateTime @default(now())

  @@index([applicantId])
}

////////////////////////////////////////////////////
// CONFIGURACION DEL SISTEMA
////////////////////////////////////////////////////

model SysConfig {
  key   String @id
  value String
}
