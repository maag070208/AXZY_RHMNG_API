generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////////////////////
// ENUMS
////////////////////////////////////////////////////

enum Role {
  ADMIN
  SHIFT_GUARD
  GUARD
}

enum AssignmentStatus {
  PENDING
  CHECKING
  UNDER_REVIEW
  REVIEWED
  ANOMALY
}

////////////////////////////////////////////////////
// USER
////////////////////////////////////////////////////

model User {
  id         Int      @id @default(autoincrement())
  name       String
  lastName   String?
  username   String   @unique
  password   String
  role       Role
  active     Boolean  @default(true)
  softDelete Boolean  @default(false)
  shiftStart String? // HH:mm
  shiftEnd   String? // HH:mm
  isLoggedIn Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  kardexEntries            Kardex[]
  assignments              Assignment[]             @relation("GuardAssignments")
  recurringConfigurations  RecurringConfiguration[] @relation("RecurringAssignments")
  recurringConfiguration   RecurringConfiguration?  @relation(fields: [recurringConfigurationId], references: [id])
  recurringConfigurationId Int?
  incidents                Incident[]
  resolvedIncidents        Incident[]               @relation("IncidentResolver")
  maintenances             Maintenance[]
  resolvedMaintenances     Maintenance[]            @relation("MaintenanceResolver")
  rounds                   Round[]                  @relation("GuardRounds")

  // Schedule Relation
  scheduleId Int?
  schedule   Schedule? @relation(fields: [scheduleId], references: [id])
}

model Schedule {
  id        Int     @id @default(autoincrement())
  name      String  @unique // e.g., "Matutino", "Vespertino"
  startTime String // "07:00"
  endTime   String // "15:00"
  active    Boolean @default(true)

  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

////////////////////////////////////////////////////
// LOCATIONS (PARKING SPOTS)
////////////////////////////////////////////////////

model Location {
  id         Int      @id @default(autoincrement())
  aisle      String
  spot       String
  number     String
  name       String   @unique
  isOccupied Boolean  @default(false)
  active     Boolean  @default(true)
  softDelete Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  kardexEntries      Kardex[]
  assignments        Assignment[]
  recurringLocations RecurringLocation[]
}

model Kardex {
  id         Int      @id @default(autoincrement())
  userId     Int
  locationId Int
  timestamp  DateTime @default(now())
  notes      String?  @db.Text
  media      Json? // Array of { type: 'IMAGE' | 'VIDEO', url: 'string' }
  latitude   Float?
  longitude  Float?

  scanType     ScanType @default(FREE)
  assignmentId Int? // Optional link to an assignment

  user       User        @relation(fields: [userId], references: [id])
  location   Location    @relation(fields: [locationId], references: [id])
  assignment Assignment? @relation(fields: [assignmentId], references: [id])

  @@index([userId])
  @@index([locationId])
  @@index([timestamp])
}

model Assignment {
  id         Int              @id @default(autoincrement())
  guardId    Int
  locationId Int
  status     AssignmentStatus @default(PENDING)
  assignedBy Int // ID of user who created assignment
  notes      String?          @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  guard    User     @relation("GuardAssignments", fields: [guardId], references: [id])
  location Location @relation(fields: [locationId], references: [id])
  kardex   Kardex[]

  tasks AssignmentTask[]

  @@index([guardId])
  @@index([locationId])
}

model AssignmentTask {
  id           Int       @id @default(autoincrement())
  assignmentId Int
  description  String
  reqPhoto     Boolean   @default(false)
  completed    Boolean   @default(false)
  completedAt  DateTime?

  assignment Assignment @relation(fields: [assignmentId], references: [id])

  @@index([assignmentId])
}

////////////////////////////////////////////////////
// RECURRING LOCATIONS
////////////////////////////////////////////////////

enum ScanType {
  ASSIGNMENT
  RECURRING
  FREE
}

model RecurringConfiguration {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  active      Boolean @default(true)

  recurringLocations RecurringLocation[]
  guards             User[]              @relation("RecurringAssignments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  rounds    Round[]
}

model RecurringLocation {
  id              Int     @id @default(autoincrement())
  configurationId Int
  locationId      Int
  active          Boolean @default(true)

  configuration RecurringConfiguration @relation(fields: [configurationId], references: [id])
  location      Location               @relation(fields: [locationId], references: [id])
  tasks         RecurringTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RecurringTask {
  id                  Int     @id @default(autoincrement())
  recurringLocationId Int
  description         String
  reqPhoto            Boolean @default(false)

  recurringLocation RecurringLocation @relation(fields: [recurringLocationId], references: [id])
}

// Update Kardex model to include scanType
// Add this below the Kardex model definition or merging it

model Incident {
  id           Int            @id @default(autoincrement())
  guardId      Int
  title        String // e.g. "Vehiculo mal estacionado"
  category     String // e.g. "MULTA", "MANTENIMIENTO", "ACCESO"
  description  String?        @db.Text
  media        Json? // Array of { type: 'IMAGE' | 'VIDEO', url: 'string' }
  status       IncidentStatus @default(PENDING)
  resolvedAt   DateTime?
  resolvedById Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guard      User  @relation(fields: [guardId], references: [id])
  resolvedBy User? @relation("IncidentResolver", fields: [resolvedById], references: [id])
}

enum IncidentStatus {
  PENDING
  ATTENDED
}

model Round {
  id        Int         @id @default(autoincrement())
  guardId   Int
  startTime DateTime    @default(now())
  endTime   DateTime?
  status    RoundStatus @default(IN_PROGRESS)

  guard User @relation("GuardRounds", fields: [guardId], references: [id])

  recurringConfigurationId Int?
  recurringConfiguration   RecurringConfiguration? @relation(fields: [recurringConfigurationId], references: [id])
}

enum RoundStatus {
  IN_PROGRESS
  COMPLETED
}

model SysConfig {
  key   String @id
  value String
}

model Maintenance {
  id           Int               @id @default(autoincrement())
  guardId      Int
  title        String
  category     String
  description  String?           @db.Text
  media        Json? // Array of { type: 'IMAGE' | 'VIDEO', url: 'string' }
  status       MaintenanceStatus @default(PENDING)
  resolvedAt   DateTime?
  resolvedById Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  guard      User  @relation(fields: [guardId], references: [id])
  resolvedBy User? @relation("MaintenanceResolver", fields: [resolvedById], references: [id])
}

enum MaintenanceStatus {
  PENDING
  ATTENDED
}
